{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": true
  },
  "exclude": ["node_modules"],
  "references": [
    { "path": "apps/web" },
    { "path": "apps/api" },
    { "path": "packages/db" }
  ]
}
