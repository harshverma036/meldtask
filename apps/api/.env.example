# Server port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL="http://localhost:3000"

# Google OAuth credentials
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID for a Web application
# 3. Add http://localhost:3001 to Authorized redirect URIs
# 4. Copy the Client ID below
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# JWT secret key for signing auth tokens
# Generate a secure random string: openssl rand -base64 64
JWT_SECRET="your-jwt-secret-here"

# PostgreSQL connection string (also used by @repo/db)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meldtask"
